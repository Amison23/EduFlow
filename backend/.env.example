# EduFlow Backend Environment Guide (.env.example)

# --- SERVER CONFIGURATION ---
PORT=3000
NODE_ENV=development

# --- SUPABASE CONFIGURATION ---
# Get these from: Supabase Dashboard -> Settings -> API
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# --- SECURITY ---
# Generate a secure random string (at least 32 chars)
JWT_SECRET=your_jwt_secret_at_least_32_chars
JWT_EXPIRY=7d

# --- AFRICA'S TALKING (SMS/OTP) ---
# Create an account at https://africastalking.com/
AFRICA_TALKING_API_KEY=your_at_api_key
AFRICA_TALKING_USERNAME=your_at_username
SMS_SHORTCODE=your_at_shortcode

# --- TWILIO (Secondary/Testing) ---
# Create an account at https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# --- SMTP GATEWAY (EMAIL) ---
# instructions in docs/SMTP_GATEWAY_SETUP.md
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="EduFlow <noreply@eduflow.app>"

# --- OPTIONAL SETTINGS ---
# OTP_EXPIRY_MINUTES=10
# JWT_EXPIRY=7d
